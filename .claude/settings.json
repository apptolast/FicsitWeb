{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "FORCE_COLOR": "1"
  },
  "teammateMode": "in-process",
  "permissions": {
    "allow": [
      "Bash(pnpm *)",
      "Bash(pnpm exec *)",
      "Bash(node *)",
      "Bash(git status)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git branch *)",
      "Bash(git checkout *)",
      "Bash(git stash *)",
      "Bash(mkdir -p *)",
      "Bash(ls *)",
      "Read(**)",
      "Edit(src/**)",
      "Edit(.claude/**)",
      "Edit(docs/**)",
      "Edit(tests/**)",
      "Edit(CLAUDE.md)",
      "Edit(package.json)",
      "Write(src/**)",
      "Write(docs/**)",
      "Write(tests/**)",
      "Write(.claude/**)"
    ],
    "deny": [
      "Bash(npm *)",
      "Bash(yarn *)",
      "Bash(bun *)",
      "Bash(rm -rf *)",
      "Bash(git push --force *)",
      "Bash(git push -f *)",
      "Bash(git reset --hard *)",
      "Write(node_modules/**)",
      "Write(dist/**)",
      "Write(.git/**)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(.claude/.mcp.env.local)",
      "Read(**/*.key)",
      "Read(**/*.pem)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.cjs\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/security-check.cjs\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/format-on-save.cjs\"",
            "timeout": 30
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/validate-task.cjs\"",
            "timeout": 120
          }
        ]
      }
    ],
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/teammate-idle.cjs\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
